# Core runtime configuration
TEMPORAL_ADDRESS=localhost:7233
TASK_QUEUE=default
TZ_DEFAULT=UTC

# API key authentication (leave blank to auto-generate on first startup)
TAPCRAFT_API_KEY=

# Encryption key for stored secrets (leave blank to auto-generate)
TAPCRAFT_SECRET_KEY=

# Git remote for workflow workspaces (optional)
GIT_REMOTE_URL=
