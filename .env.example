# Core runtime configuration
TEMPORAL_ADDRESS=localhost:7233
TASK_QUEUE=default
TZ_DEFAULT=UTC

# Git remote for generated modules (optional)
GIT_REMOTE_URL=

# Agent model configuration
AGENT_PLANNER_MODEL=gpt-4o-mini
AGENT_GENERATOR_MODEL=gpt-4o
AGENT_REPAIR_MODEL=gpt-4o
AGENT_TEST_MODEL=gpt-4o-mini

# Agent token budgets and limits
AGENT_MAX_TOKENS_PLAN=1500
AGENT_MAX_TOKENS_GEN=8000
AGENT_MAX_TOKENS_REPAIR=4000
AGENT_MAX_TOKENS_TESTS=2000
AGENT_RATE_LIMIT_RPM=60

# Agent caching configuration
AGENT_PLAN_CACHE_TTL_SECONDS=600
